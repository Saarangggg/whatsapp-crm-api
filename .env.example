# Basic Authentication Credentials for UI (/chat or /client)
AUTH_USER=yourname
AUTH_PASSWORD=your-secure-password

# Shared API secret used to sign/verify requests between backend and whatsapp-service
WA_SECRET=your-secret-key

# Node service port
PORT=3001

# Webhook URL to forward incoming messages (can be any API, server, or webhook endpoint)
BACKEND_URL=your-backend-webhook-url

# Admin phone number (with country code, no +) to bypass AI auto-replies and receive system alerts
ADMIN_PHONE=your-admin-phone

# External API URL for store, database, or CRM integrations
EXTERNAL_API_URL=your-external-api-url


# OpenRouter API Key for AI Autoreplies (Optional fallback, can also be configured via Web UI settings)
OPENROUTER_API_KEY=your-openrouter-api-key

# Path to the text/markdown file containing your custom AI System Prompt context (relative to code directory).
# If this file exists, the server will read the prompt directly from it.
SYSTEM_PROMPT_FILE=ai-context.md

# System Prompt Context string for AI Autoreplies (Optional fallback if SYSTEM_PROMPT_FILE does not exist)
SYSTEM_PROMPT="You are a helpful customer service AI assistant."


